{
  "openapi": "3.0.0",
  "info": {
    "title": "RapidCron API",
    "description": "RapidCron是一个基于Rust的分布式任务调度系统",
    "version": "1.0.0"
  },
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "用户登录",
        "description": "使用用户名和密码登录系统",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseLogin"
                }
              }
            }
          },
          "401": {
            "description": "用户名或密码错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseError"
                }
              }
            }
          }
        }
      }
    },
    "/tasks": {
      "get": {
        "summary": "获取任务列表",
        "description": "获取所有任务的列表，支持分页和过滤",
        "parameters": [
          {
            "name": "enabled",
            "in": "query",
            "description": "是否启用",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "任务名称（模糊查询）",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "task_type",
            "in": "query",
            "description": "任务类型",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "command",
                "http"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "页码",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "每页数量",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseTaskList"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "创建任务",
        "description": "创建一个新的任务",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseTask"
                }
              }
            }
          },
          "400": {
            "description": "参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseError"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{id}": {
      "get": {
        "summary": "获取任务详情",
        "description": "根据ID获取任务的详细信息",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "任务ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseTask"
                }
              }
            }
          },
          "404": {
            "description": "任务不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseError"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "更新任务",
        "description": "更新任务的信息",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "任务ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseTask"
                }
              }
            }
          },
          "400": {
            "description": "参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseError"
                }
              }
            }
          },
          "404": {
            "description": "任务不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "删除任务",
        "description": "删除任务（软删除）",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "任务ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseString"
                }
              }
            }
          },
          "404": {
            "description": "任务不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseError"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{id}/enable": {
      "post": {
        "summary": "启用任务",
        "description": "启用指定的任务",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "任务ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseTask"
                }
              }
            }
          },
          "404": {
            "description": "任务不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseError"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{id}/disable": {
      "post": {
        "summary": "禁用任务",
        "description": "禁用指定的任务",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "任务ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseTask"
                }
              }
            }
          },
          "404": {
            "description": "任务不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseError"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{id}/trigger": {
      "post": {
        "summary": "手动触发任务",
        "description": "手动触发指定的任务执行",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "任务ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TriggerTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseTaskInstance"
                }
              }
            }
          },
          "404": {
            "description": "任务不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseError"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/instances": {
      "get": {
        "summary": "获取任务实例列表",
        "description": "获取任务实例的列表，支持分页和过滤",
        "parameters": [
          {
            "name": "task_id",
            "in": "query",
            "description": "任务ID",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "任务状态",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "running",
                "success",
                "failed",
                "cancelled"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "页码",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "每页数量",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseTaskInstanceList"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/instances/{id}": {
      "get": {
        "summary": "获取任务实例详情",
        "description": "根据ID获取任务实例的详细信息",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "任务实例ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseTaskInstance"
                }
              }
            }
          },
          "404": {
            "description": "任务实例不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseError"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/stats": {
      "get": {
        "summary": "获取统计信息",
        "description": "获取系统的统计信息",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseStats"
                }
              }
            }
          }
        }
      }
    },
    "/execution/logs": {
      "get": {
        "summary": "获取执行日志列表",
        "description": "获取执行日志的列表，支持分页和过滤",
        "parameters": [
          {
            "name": "task_id",
            "in": "query",
            "description": "任务ID",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "instance_id",
            "in": "query",
            "description": "实例ID",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "任务状态",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "running",
                "success",
                "failed",
                "cancelled"
              ]
            }
          },
          {
            "name": "triggered_by",
            "in": "query",
            "description": "触发方式",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "scheduler",
                "manual"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "页码",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "每页数量",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseExecutionLogList"
                }
              }
            }
          }
        }
      }
    },
    "/execution/logs/{id}": {
      "get": {
        "summary": "获取执行日志详情",
        "description": "根据ID获取执行日志的详细信息",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "执行日志ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseExecutionLog"
                }
              }
            }
          },
          "404": {
            "description": "执行日志不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseError"
                }
              }
            }
          }
        }
      }
    },
    "/clusters/info": {
      "get": {
        "summary": "获取集群信息",
        "description": "获取集群的详细信息，包括节点状态等",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseCluster"
                }
              }
            }
          }
        }
      }
    },
    "/dispatch/logs": {
      "get": {
        "summary": "获取分发日志列表",
        "description": "获取分发日志的列表，支持分页和过滤",
        "parameters": [
          {
            "name": "start_time",
            "in": "query",
            "required": false,
            "description": "扫描开始时间（ISO 8601格式）",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end_time",
            "in": "query",
            "required": false,
            "description": "扫描结束时间（ISO 8601格式）",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "has_error",
            "in": "query",
            "required": false,
            "description": "是否有错误",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "页码",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "description": "每页数量",
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponsePaginatedDispatchLog"
                }
              }
            }
          }
        }
      }
    },
    "/dispatch/logs/{id}": {
      "get": {
        "summary": "获取分发日志详情",
        "description": "根据ID获取分发日志的详细信息",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "分发日志ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseDispatchLog"
                }
              }
            }
          },
          "404": {
            "description": "分发日志不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "password": {
            "type": "string",
            "description": "密码"
          }
        }
      },
      "UserInfo": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "role": {
            "type": "string",
            "description": "用户角色"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "登录状态"
          },
          "message": {
            "type": "string",
            "description": "登录消息"
          },
          "user": {
            "$ref": "#/components/schemas/UserInfo"
          }
        }
      },
      "CreateTaskRequest": {
        "type": "object",
        "required": [
          "name",
          "schedule"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "任务名称",
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "description": "任务描述",
            "maxLength": 500
          },
          "dependency_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "依赖任务ID列表"
          },
          "type": {
            "type": "string",
            "description": "任务类型",
            "enum": [
              "command",
              "http"
            ]
          },
          "schedule": {
            "type": "string",
            "description": "Cron表达式"
          },
          "enabled": {
            "type": "boolean",
            "description": "是否启用",
            "default": false
          },
          "command": {
            "type": "string",
            "description": "命令内容（命令类型任务）"
          },
          "url": {
            "type": "string",
            "description": "URL地址（HTTP类型任务）"
          },
          "timeout_seconds": {
            "type": "integer",
            "description": "超时时间（秒）",
            "minimum": 1,
            "maximum": 3600
          },
          "max_retries": {
            "type": "integer",
            "description": "最大重试次数",
            "minimum": 0,
            "maximum": 10
          }
        }
      },
      "UpdateTaskRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "任务名称",
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "description": "任务描述",
            "maxLength": 500
          },
          "dependency_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "依赖任务ID列表"
          },
          "schedule": {
            "type": "string",
            "description": "Cron表达式"
          },
          "enabled": {
            "type": "boolean",
            "description": "是否启用"
          },
          "task_type": {
            "type": "string",
            "description": "任务类型",
            "enum": [
              "command",
              "http"
            ]
          },
          "command": {
            "type": "string",
            "description": "命令内容（命令类型任务）"
          },
          "url": {
            "type": "string",
            "description": "URL地址（HTTP类型任务）"
          },
          "timeout_seconds": {
            "type": "integer",
            "description": "超时时间（秒）",
            "minimum": 1,
            "maximum": 3600
          },
          "max_retries": {
            "type": "integer",
            "description": "最大重试次数",
            "minimum": 0,
            "maximum": 10
          }
        }
      },
      "TriggerTaskRequest": {
        "type": "object",
        "properties": {
          "scheduled_time": {
            "type": "integer",
            "description": "计划执行时间戳（秒）"
          }
        }
      },
      "TaskType": {
        "type": "string",
        "enum": [
          "command",
          "http"
        ]
      },
      "TaskStatus": {
        "type": "string",
        "enum": [
          "pending",
          "running",
          "success",
          "failed",
          "cancelled"
        ]
      },
      "TriggeredBy": {
        "type": "string",
        "enum": [
          "scheduler",
          "manual"
        ],
        "description": "任务触发方式"
      },
      "TaskPayload": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "command": {
                "type": "string"
              },
              "timeout_seconds": {
                "type": "integer"
              }
            },
            "required": [
              "command"
            ]
          },
          {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              },
              "method": {
                "type": "string"
              },
              "headers": {
                "type": "object"
              },
              "body": {
                "type": "string"
              },
              "timeout_seconds": {
                "type": "integer"
              }
            },
            "required": [
              "url"
            ]
          }
        ]
      },
      "Task": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "description": "任务ID"
          },
          "name": {
            "type": "string",
            "description": "任务名称"
          },
          "description": {
            "type": "string",
